<?xml version="1.0" encoding="UTF-8" standalone="no"?>
<Form Key="PM_Default4ObjectTypes" Caption="定义对象类型的基于事务缺省值" FormType="Entity" InitState="Default" Version="17" DeliveryClass="C">
    <DataSource>
        <DataObject Key="PM_Default4ObjectTypes" Caption="对象类型的基于事务缺省值" PrimaryType="Entity" Version="1">
            <TableCollection>
                <Table Key="EPM_Default4ObjectTypes" Caption="定义对象类型的基于事务缺省值明细" TableMode="Detail" IndexPrefix="EPM_Default4ObjectTypes">
                    <Column Key="OID" Caption="对象标识" DataElementKey="OID"/>
                    <Column Key="SOID" Caption="主对象标识" DataElementKey="SOID"/>
                    <Column Key="POID" Caption="父对象标识" DataElementKey="POID"/>
                    <Column Key="VERID" Caption="对象版本" DataElementKey="VERID"/>
                    <Column Key="DVERID" Caption="对象明细版本" DataElementKey="DVERID"/>
                    <Column Key="TCodeID" Caption="事务码" CodeColumnKey="TCodeCode" DataElementKey="TCodeID" PrimaryKey="true"/>
                    <Column Key="DynObjectTypeID" Caption="对象类别" DataElementKey="DynObjectTypeID" RefItemKeyCol="DynObjectTypeIDDEKey"/>
                    <Column Key="DynObjectTypeIDDEKey" Caption="对象类别字典标识" DataElementKey="DynObjectTypeIDDEKey"/>
                    <Column Key="TCodeCode" Caption="事务码代号" SortType="Asc" DataElementKey="Code_50"/>
                    <Column Key="ExternalSystemPrimaryKey" Caption="外部系统关键字" DataElementKey="ExternalSystemPrimaryKey"/>
                </Table>
            </TableCollection>
        </DataObject>
    </DataSource>
    <OperationCollection>
        <Operation Key="BillEdit" Caption="修改" RefKey="BillEdit" TCode="'OIAT'" Activity="02"/>
        <Operation Key="BillSave" Caption="保存" RefKey="BillSave"/>
        <Operation Key="BillCancel" Caption="取消" RefKey="BillCancel"/>
        <Operation Key="ShowDataLog" Caption="查看数据日志" RefKey="ShowDataLog"/>
        <Operation Key="PositionCursor" Caption="定位" RefKey="PositionCursor"/>
        <Operation Key="UIClose" Caption="关闭" RefKey="UIClose"/>
    </OperationCollection>
    <Body>
        <Block>
            <FlexFlowLayoutPanel Key="root">
                <ToolBar Key="ToolBar1" Caption="ToolBar1" Height="pref">
                    <ToolBarItemCollection/>
                </ToolBar>
                <GridLayoutPanel Key="main_container" Height="100%" OverflowY="Auto">
                    <Grid Key="ObjectTypesGrid" Caption="定义对象类型的基于事务缺省值" DefaultFitWidth="true" SerialSeq="true" X="0" Y="0" Padding="8px">
                        <GridColumnCollection>
                            <GridColumn Key="IsSelect" Enable="true" Width="32px"/>
                            <GridColumn Key="TCodeID" Caption="事务码" Width="80px"/>
                            <GridColumn Key="DynObjectTypeID" Caption="对象类别" LabelType="M" Width="80px"/>
                            <GridColumn Key="DynObjectTypeIDDEKey" Caption="对象类别字典DataElementKey" LabelType="H" Visible="false" Width="80px"/>
                            <GridColumn Key="SOID" Visible="false" Width="80px"/>
                            <GridColumn Key="Dtl_ExternalSystemPrimaryKey" Caption="外部系统关键字" LabelType="H" Visible="false" Width="100px"/>
                        </GridColumnCollection>
                        <GridRowCollection>
                            <GridRow Key="ObjectTypesGridRow" TableKey="EPM_Default4ObjectTypes">
                                <GridCell Key="IsSelect" Caption="选择" CellType="CheckBox" Enable="true" IsSelect="true"/>
                                <GridCell Key="TCodeID" Caption="事务码" CellType="Dict" Enable="false" ItemKey="TCode">
                                    <DataBinding ColumnKey="TCodeID"/>
                                </GridCell>
                                <GridCell Key="DynObjectTypeID" Caption="对象类别" CellType="DynamicDict" IsDynamic="true" RefDataElementKey="DynObjectTypeIDDEKey">
                                    <DataBinding ColumnKey="DynObjectTypeID"/>
                                </GridCell>
                                <GridCell Key="DynObjectTypeIDDEKey" Caption="对象类别字典DataElementKey" CellType="TextEditor">
                                    <DataBinding ColumnKey="DynObjectTypeIDDEKey" DefaultFormulaValue="Macro_HeadOrderCategorySelect(TCodeID)"/>
                                </GridCell>
                                <GridCell Key="SOID" CellType="NumberEditor" Scale="0">
                                    <DataBinding ColumnKey="SOID"/>
                                </GridCell>
                                <GridCell Key="Dtl_ExternalSystemPrimaryKey" Caption="外部系统关键字" CellType="TextEditor">
                                    <DataBinding ColumnKey="ExternalSystemPrimaryKey"/>
                                </GridCell>
                            </GridRow>
                        </GridRowCollection>
                    </Grid>
                    <RowDefCollection RowGap="24">
                        <RowDef Height="100%"/>
                    </RowDefCollection>
                    <ColumnDefCollection ColumnGap="16">
                        <ColumnDef Width="100%"/>
                    </ColumnDefCollection>
                </GridLayoutPanel>
            </FlexFlowLayoutPanel>
        </Block>
    </Body>
    <OnLoad>
        <![CDATA[Macro_LoadObject()]]>
    </OnLoad>
    <MacroCollection>
        <Macro Key="Macro_HeadOrderCategorySelect" Args="TCodeID">
            <![CDATA[var dict = com.bokesoft.erp.pm.function.EquipmentFormula.getDicFromTCode(GetDictValue('TCode', TCodeID, 'Code'));
                 IIFS(dict == 'PM_EquipmentCategory','EquipmentCategoryID',dict == 'PM_FunctionalLocationCategory','FunctionalLocationCategoryID',dict == 'PM_MeasuringPointCategory','MeasuringPointCategoryID',true,'EquipmentCategoryID');]]>
        </Macro>
    </MacroCollection>
</Form>
