                    <Column Key="SupEquipmentSOID" Caption="高级设备" Persist="false" IgnoreQuery="true" DataElementKey="EquipmentSOID"/>
                    <Column Key="CatalogProfileID" Caption="类别参数文件" Persist="false" IgnoreQuery="true" DataElementKey="CatalogProfileID"/>
                    <Column Key="ClassificationID" Caption="分类" Persist="false" DataElementKey="ClassificationID" IgnoreQuery="true"/>
                    <Column Key="CompanyCodeID" Caption="公司代码" Persist="false" DataElementKey="CompanyCodeID" IgnoreQuery="true"/>
