                        </GridRowCollection>
                        <RowDblClick>
                            <![CDATA[PushPara('_TimeSegmentID',TimeSegmentID);Macro_OpenBill();SetValue('IsProcessed', 1);]]>
                        </RowDblClick>
                    </Grid>
                    <RowDefCollection RowGap="24">
                        <RowDef Height="100%"/>
                    </RowDefCollection>
                    <ColumnDefCollection ColumnGap="16">
                        <ColumnDef Width="100%"/>
                    </ColumnDefCollection>
                </GridLayoutPanel>
            </FlexFlowLayoutPanel>
