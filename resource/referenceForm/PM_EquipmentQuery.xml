    </Body>
    <OnLoad>
        <![CDATA[SetPara('RptIsEditMode', IIF(GetEntryPara('TCode') == 'IE05', 1, 0)); ERPShowModal('Cond_PM_EquipmentQuery')]]>
    </OnLoad>
    <MacroCollection>
        <Macro Key="Macro_CreateMaintenanceOrder">
            <![CDATA[var selBillID = GetSelDtlFldValue('SOID', ',');
IIFS(Length(selBillID)==0,IIF(GetFocusRow('EquipmentQueryResultGrid') >= 0,ERPShowModal('PM_CreateMaintenanceOrder', 'Macro_ShowEvent(' + SOID + ', 0)', 'newtab'),ConfirmMsg('PM_MAINTENANCEORDER023','请勾选一行',{})),IndexOf(selBillID,',') > 0,ConfirmMsg('PM_MAINTENANCEORDER024','不支持多选创建',{}),ERPShowModal('PM_CreateMaintenanceOrder', 'Macro_ShowEvent(' + selBillID + ', 0)', 'newtab'))]]>
        </Macro>
        <Macro Key="Macro_OpenBill">
            <![CDATA[ERPShowModal('PM_Equipment', 'Macro_PM_EquipmentQuery_ShowEvent(' + SOID + ',' + (GetPara('RptIsEditMode') == 1) + ')', 'newtab')]]>
        </Macro>
        <Macro Key="Macro_LoadUsageListShowEvent" Args="EquipmentID">
            <![CDATA[Macro_SetTableFilter(0, 'SOID = '&SqlPara(EquipmentID));Macro_LoadObject()]]>
        </Macro>
        <Macro Key="Macro_UnionHistory">
            <![CDATA[if(GetPara('_IsUsageList')){'union all select '&com.bokesoft.erp.pm.masterdata.EquipmentHistory.mergeEquipAndHistoryQueryCols('h.', 's.',Macro_SelectColumnKeys())&','&Macro_T('EMM_SNNumberHead','EquipmentNotes','h')&' EquipmentNotes'&' ,(select CategoryTypeID from EGS_Object_Classification c where c.soid = h.oid group by CategoryTypeID) CategoryTypeID,
					   (select ClassificationIDs from EGS_Object_Classification oc where oc.soid = h.oid GROUP BY ClassificationIDs) ClassificationID from emm_snnumberhead h inner join EPM_EquipmentTimeSegment s on h.soid = s.EquipmentSOID  where ('&'EquipSerialNumberStatus='&SqlPara('1')&' or EquipSerialNumberStatus='&SqlPara('2')&')'}]]>
        </Macro>
        <Macro Key="Macro_SelectColumnKeys">
            <![CDATA['OID,
       SOID,
       POID,
       VERID,
       DVERID,
	   ValidStartDate,
	   ValidEndDate,
       EquipmentCategoryID,
       EquipSNStatusText,
       EquipSerialNumberStatus,
       DocumentNumber,
       MaintPlantID,
       PlanningPlantID,
       WorkCenterID,
       AssetCardSOID,
       OrgCompanyCodeID,
       BusinessAreaID,
       CostCenterID,
       ControllingAreaID,
       PlannerGroupID,
       EquipUserStatusText,
       StartDate,
       TechnicalObjectID,
       Manufacturer,
       ManufCountryID,
       ModelNumber,
       ConstYear,
       ConstMon,
       AssetCardDocNo,
       MainWorkCenterID,
       CatalogProfileID,
       FunctionalLocationSOID,
       EquipmentSOID,
       MaterialID,
       LocationID,
       Room,
       PlantSectionID,
       ABCIndicatorID,
       Creator,
       CreateTime,
       Modifier,
       ModifyTime,
       TimeSegmentID,
			 SerialNumber,
WBSElementID,
SortField,
StructTypeID']]>
        </Macro>
        <Macro Key="Macro_SelectOtherColumnKeys">
            <![CDATA['
					   (select CategoryTypeID from EGS_Object_Classification c where c.soid = emm_snnumberhead.oid group by CategoryTypeID) CategoryTypeID,
					   (select ClassificationIDs from EGS_Object_Classification oc where oc.soid = emm_snnumberhead.oid GROUP BY ClassificationIDs) ClassificationID
']]>
        </Macro>
    </MacroCollection>
</Form>
