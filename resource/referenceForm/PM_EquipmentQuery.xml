<?xml version="1.0" encoding="UTF-8" standalone="no"?>
<Form Key="PM_EquipmentQuery" FormType="Entity" FormulaCaption="IIFS(GetEntryPara('TCode') == 'IE05', '设备列表编辑', GetEntryPara('TCode') == 'IH08', '设备列表显示', true, '设备查询')" InitState="Default" Version="44">
    <DataSource>
        <DataObject Key="PM_Equipment_Query" Caption="设备查询" PrimaryType="Entity" Version="1">
            <TableCollection>
                <Table Key="EPM_Equipment_Query" Caption="设备清单" TableMode="Detail" SourceType="Query" Persist="false" OrderBy="'CreateTime Desc,DocumentNumber Desc'">
                    <Column Key="OID" Caption="对象标识" DataElementKey="OID"/>
                    <Column Key="SOID" Caption="主对象标识" DataElementKey="SOID"/>
                    <Column Key="POID" Caption="父对象标识" DataElementKey="POID"/>
                    <Column Key="VERID" Caption="对象版本" DataElementKey="VERID"/>
                    <Column Key="DVERID" Caption="对象明细版本" DataElementKey="DVERID"/>
                    <Column Key="EquipmentCategoryID" Caption="设备种类" DataElementKey="EquipmentCategoryID"/>
                    <Column Key="EquipmentNotes" Caption="设备描述" DefaultValue="" DataElementKey="EquipmentNotes"/>
                    <Column Key="EquipSNStatusText" Caption="系统状态" DefaultValue="" DataElementKey="EquipSNStatusText"/>
                    <Column Key="EquipSerialNumberStatus" Caption="设备和序列号状态" DataElementKey="EquipSerialNumberStatus"/>
                    <Column Key="DocumentNumber" Caption="设备" DefaultValue="" DataElementKey="DocumentNumber"/>
                    <Column Key="MaintPlantID" Caption="维护工厂" DataElementKey="MaintPlantID"/>
                    <Column Key="PlanningPlantID" Caption="计划工厂" DataElementKey="PlanningPlantID"/>
                    <Column Key="WorkCenterID" Caption="工作中心" DataElementKey="TecoObjectWorkCenterID"/>
                    <Column Key="AssetCardSOID" Caption="资产" DataElementKey="AssetCardSOID"/>
                    <Column Key="OrgCompanyCodeID" Caption="公司代码" DataElementKey="CompanyCodeID"/>
                    <Column Key="BusinessAreaID" Caption="业务范围" DataElementKey="BusinessAreaID"/>
                    <Column Key="CostCenterID" Caption="成本中心" DataElementKey="CostCenterID"/>
                    <Column Key="ControllingAreaID" Caption="控制范围" DataElementKey="ControllingAreaID"/>
                    <Column Key="PlannerGroupID" Caption="计划人员组" DataElementKey="PMPlannerGroupID"/>
                    <Column Key="EquipUserStatusText" Caption="用户状态" DataElementKey="EquipUserStatusText"/>
                    <Column Key="StartDate" Caption="开始日期" DataElementKey="TechObjectStartupDate"/>
                    <Column Key="TechnicalObjectID" Caption="技术对象类型" DataElementKey="TechnicalObjectID"/>
                    <Column Key="Manufacturer" Caption="制造商" DataElementKey="Manufacturer"/>
                    <Column Key="ManufCountryID" Caption="制造商国家" DataElementKey="ManufCountryID"/>
                    <Column Key="ModelNumber" Caption="型号" DataElementKey="ModelNumber"/>
                    <Column Key="ConstYear" Caption="制造年" DataElementKey="ConstYear"/>
                    <Column Key="ConstMon" Caption="制造月" DataElementKey="ConstMon"/>
                    <Column Key="AssetCardDocNo" Caption="资产号" DataElementKey="DocumentNumber"/>
                    <Column Key="MainWorkCenterID" Caption="主工作中心" DataElementKey="MainWorkCenterID"/>
                    <Column Key="CatalogProfileID" Caption="类别参数文件" DataElementKey="CatalogProfileID"/>
                    <Column Key="FunctionalLocationSOID" Caption="功能位置" DataElementKey="FunctionalLocationSOID"/>
                    <Column Key="EquipmentSOID" Caption="高级设备" DataElementKey="EquipmentSOID"/>
                    <Column Key="MaterialID" Caption="物料" DataElementKey="MaterialID"/>
                    <Column Key="LocationID" Caption="位置" DataElementKey="LocationID"/>
                    <Column Key="Room" Caption="房间" DataElementKey="Room"/>
                    <Column Key="PlantSectionID" Caption="工厂区域" DataElementKey="PlantSectionID"/>
                    <Column Key="ABCIndicatorID" Caption="ABC标识" DataElementKey="ABCIndicatorID"/>
                    <Column Key="Creator" Caption="制单人" DataElementKey="Creator"/>
                    <Column Key="CreateTime" Caption="制单时间" DataElementKey="CreateTime"/>
                    <Column Key="Modifier" Caption="修改人" DataElementKey="Modifier"/>
                    <Column Key="ModifyTime" Caption="修改时间" DataElementKey="ModifyTime"/>
                    <Column Key="TimeSegmentID" Caption="时间段" DataElementKey="TimeSegmentID"/>
                    <Column Key="ValidStartDate" Caption="有效起始日" DataElementKey="ValidStartDate"/>
                    <Column Key="ValidEndDate" Caption="有效截止日" DataElementKey="ValidEndDate"/>
                    <Column Key="SerialNumber" Caption="序列号" DataElementKey="SerialNumber"/>
                    <Column Key="CategoryTypeID" Caption="类别种类" DataElementKey="CategoryTypeID"/>
                    <Column Key="SortField" Caption="分类字段" DataElementKey="SortField"/>
                    <Column Key="WBSElementID" Caption="WBS元素" DataElementKey="WBSElementID"/>
                    <Column Key="ClassificationID" Caption="分类" DataElementKey="ClassificationID_Multi"/>
                    <Column Key="StructTypeID" Caption="构造类型" DataElementKey="StructTypeID"/>
                    <Column Key="IsProcessed" Caption="已处理" Persist="false" DataElementKey="IsProcessed" IgnoreQuery="true"/>
                    <Statement Type="Formula">
                        <![CDATA['select '&Macro_SelectColumnKeys()&','&Macro_T('EMM_SNNumberHead','EquipmentNotes','')&' EquipmentNotes'&', '&Macro_SelectOtherColumnKeys()&' from emm_snnumberhead where ('&'EquipSerialNumberStatus='&SqlPara('1')&' or EquipSerialNumberStatus='&SqlPara('2')&')'&Macro_UnionHistory()]]>
                    </Statement>
                </Table>
            </TableCollection>
        </DataObject>
    </DataSource>
    <OperationCollection>
        <Operation Key="Filter" Caption="重新选择" Visible="!GetPara('_IsUsageList')" Enable="true">
            <Action>
                <![CDATA[ERPShowModal('Cond_PM_EquipmentQuery')]]>
            </Action>
        </Operation>
        <Operation Key="Refresh" Caption="刷新" RefKey="Refresh"/>
        <Operation Key="ToEditMode" Caption="显示模式 -&gt; 编辑模式" Visible="GetPara('RptIsEditMode') == 0 &amp;&amp; (GetEntryPara('TCode') == 'IE05' || GetEntryPara('TCode') == 'IH08')" Enable="true">
            <Action>
                <![CDATA[SetPara('RptIsEditMode', 1);RefreshOperation()]]>
            </Action>
        </Operation>
        <Operation Key="ToReadMode" Caption="编辑模式 -&gt; 显示模式" Visible="GetPara('RptIsEditMode') == 1 &amp;&amp; (GetEntryPara('TCode') == 'IE05' || GetEntryPara('TCode') == 'IH08')" Enable="true">
            <Action>
                <![CDATA[SetPara('RptIsEditMode', 0);RefreshOperation()]]>
            </Action>
        </Operation>
        <Operation Key="CreateMaintenanceOrder" Caption="创建维护订单" Visible="GetEntryPara('TCode') == 'IE05' || GetEntryPara('TCode') == 'IH08'" Enable="GetRowCount('EquipmentQueryResultGrid') &gt; 0" Activity="01">
            <Action>
                <![CDATA[Macro_CreateMaintenanceOrder()]]>
            </Action>
        </Operation>
        <OperationCollection Key="NewPrint" Caption="打印" SelfDisable="true">
            <Operation Key="NewPrintDefault" Caption="默认模板打印" RefKey="NewPrintDefault" Activity="04"/>
            <Operation Key="NewPrintSelect" Caption="其他模板选择" RefKey="NewPrintSelect" Activity="04"/>
            <Operation Key="ManagePrint" Caption="打印模板管理" RefKey="ManagePrint" Activity="04"/>
        </OperationCollection>
        <OperationCollection Key="NewPrePrint" Caption="打印预览" SelfDisable="true">
            <Operation Key="NewPrePrintDefault" Caption="默认模板预览" RefKey="NewPrePrintDefault" Activity="Y09"/>
            <Operation Key="NewPrePrintSelect" Caption="其他模板选择" RefKey="NewPrePrintSelect" Activity="Y09"/>
        </OperationCollection>
        <Operation Key="ERPExportExcel" Caption="导出" RefKey="ERPExportExcel" Activity="Y11"/>
        <Operation Key="UIClose" Caption="关闭" RefKey="UIClose"/>
    </OperationCollection>
    <Body>
        <Block>
            <FlexFlowLayoutPanel Key="root">
                <ToolBar Key="ToolBar1" Caption="ToolBar1" Height="pref">
                    <ToolBarItemCollection/>
                </ToolBar>
                <GridLayoutPanel Key="main_container" Height="100%" OverflowY="Auto">
