                            <GridColumn Key="ValidEndDate" Caption="有效截止日" Visible="GetPara('_IsUsageList')" Width="100px"/>
                            <GridColumn Key="EquipSNStatusText" Caption="系统状态" LabelType="H" Width="80px"/>
                            <GridColumn Key="EquipUserStatusText" Caption="用户状态" LabelType="H" Width="80px"/>
                            <GridColumn Key="StartDate" Caption="开始日期" LabelType="M" Width="100px"/>
                            <GridColumn Key="TechnicalObjectID" Caption="技术对象类型" LabelType="L" Width="120px"/>
                            <GridColumn Key="Manufacturer" Caption="制造商" LabelType="M" Width="80px"/>
                            <GridColumn Key="ManufCountryID" Caption="制造商国家" LabelType="M" Width="100px"/>
                            <GridColumn Key="ModelNumber" Caption="型号" LabelType="H" Width="80px"/>
                            <GridColumn Key="ConstYear" Caption="制造年" LabelType="M" Width="80px"/>
                            <GridColumn Key="ConstMon" Caption="制造月" LabelType="M" Width="80px"/>
                            <GridColumn Key="OrgCompanyCodeID" Caption="公司代码" LabelType="M" Width="80px"/>
                            <GridColumn Key="AssetCardDocNo" Caption="资产号" Width="80px"/>
                            <GridColumn Key="CostCenterID" Caption="成本中心" LabelType="H" Width="80px"/>
                            <GridColumn Key="PlanningPlantID" Caption="计划工厂" LabelType="M" Width="80px"/>
                            <GridColumn Key="PlannerGroupID" Caption="计划员组" LabelType="S" Width="80px"/>
                            <GridColumn Key="MainWorkCenterID" Caption="主工作中心" LabelType="M" Width="100px"/>
                            <GridColumn Key="CatalogProfileID" Caption="类别参数文件" LabelType="M" Width="120px"/>
                            <GridColumn Key="FunctionalLocationSOID" Caption="功能位置" LabelType="H" Width="80px"/>
                            <GridColumn Key="SupEquipmentSOID" Caption="高级设备" Width="80px"/>
                            <GridColumn Key="MaterialID" Caption="物料" LabelType="H" Width="80px"/>
                            <GridColumn Key="MaintPlantID" Caption="维护工厂" LabelType="M" Width="80px"/>
                            <GridColumn Key="LocationID" Caption="位置" LabelType="H" Width="80px"/>
                            <GridColumn Key="Room" Caption="房间" LabelType="H" Width="80px"/>
                            <GridColumn Key="PlantSectionID" Caption="工厂区域" LabelType="M" Width="80px"/>
                            <GridColumn Key="WorkCenterID" Caption="工作中心" LabelType="M" Width="80px"/>
                            <GridColumn Key="ABCIndicatorID" Caption="ABC标识" LabelType="M" Width="80px"/>
                            <GridColumn Key="Creator" Caption="创建人" Width="80px"/>
                            <GridColumn Key="CreateTime" Caption="创建日期" Width="160px"/>
                            <GridColumn Key="Modifier" Caption="更改人" Width="80px"/>
                            <GridColumn Key="ModifyTime" Caption="更改时间" Width="160px"/>
                            <GridColumn Key="EquipmentCategoryID" Caption="设备种类" LabelType="M" Width="80px"/>
                            <GridColumn Key="EquipSerialNumberStatus" Caption="设备和序列号状态" LabelType="H" Width="80px"/>
                            <GridColumn Key="SerialNumber" Caption="序列号" LabelType="H" Width="80px"/>
                            <GridColumn Key="CategoryTypeID" Caption="类别种类" LabelType="M" Width="160px"/>
                            <GridColumn Key="SortField" Caption="分类字段" LabelType="H" Width="160px"/>
                            <GridColumn Key="WBSElementID" Caption="WBS元素" LabelType="M" Width="160px"/>
                            <GridColumn Key="ClassificationID" Caption="分类" LabelType="H" Width="160px"/>
                            <GridColumn Key="BussinessAreaID" Caption="业务范围" LabelType="M" Width="80px"/>
                            <GridColumn Key="SOID" Caption="SOID" Visible="false" Width="80px"/>
                            <GridColumn Key="TimeSegmentID" Caption="TimeSegmentID" LabelType="H" Visible="false" Width="80px"/>
                        </GridColumnCollection>
                        <GridRowCollection>
                            <GridRow Key="RowInEquipmentQueryResultGrid" TableKey="EPM_Equipment_Query">
                                <GridCell Key="IsSelect" Caption="选择" CellType="CheckBox" IsSelect="true"/>
                                <GridCell Key="IsProcessed" Caption="已处理" CellType="CheckBox">
                                    <DataBinding ColumnKey="IsProcessed"/>
                                </GridCell>
                                <GridCell Key="EquipmentDocNo" Caption="设备" CellType="TextEditor" MaxLength="100" Trim="true">
                                    <DataBinding ColumnKey="DocumentNumber"/>
                                </GridCell>
                                <GridCell Key="EquipmentNotes" Caption="设备描述" CellType="TextEditor" MaxLength="100" Trim="true">
                                    <DataBinding ColumnKey="EquipmentNotes"/>
                                </GridCell>
                                <GridCell Key="ValidStartDate" Caption="有效起始日" CellType="UTCDatePicker">
                                    <DataBinding ColumnKey="ValidStartDate"/>
                                </GridCell>
                                <GridCell Key="ValidEndDate" Caption="有效截止日" CellType="UTCDatePicker">
                                    <DataBinding ColumnKey="ValidEndDate"/>
                                </GridCell>
                                <GridCell Key="EquipSNStatusText" Caption="系统状态" CellType="TextEditor" MaxLength="100" Trim="true">
                                    <DataBinding ColumnKey="EquipSNStatusText"/>
                                </GridCell>
                                <GridCell Key="EquipUserStatusText" Caption="用户状态" CellType="TextEditor" MaxLength="100">
                                    <DataBinding ColumnKey="EquipUserStatusText"/>
                                </GridCell>
                                <GridCell Key="StartDate" Caption="开始日期" CellType="UTCDatePicker">
                                    <DataBinding ColumnKey="StartDate"/>
                                </GridCell>
                                <GridCell Key="TechnicalObjectID" Caption="技术对象类型" CellType="Dict" ItemKey="PM_TechnicalObject">
                                    <DataBinding ColumnKey="TechnicalObjectID"/>
                                </GridCell>
                                <GridCell Key="Manufacturer" Caption="制造商" CellType="TextEditor" MaxLength="30">
                                    <DataBinding ColumnKey="Manufacturer"/>
                                </GridCell>
                                <GridCell Key="ManufCountryID" Caption="制造商国家" CellType="Dict" ItemKey="Country">
                                    <DataBinding ColumnKey="ManufCountryID"/>
                                </GridCell>
                                <GridCell Key="ModelNumber" Caption="型号" CellType="TextEditor" MaxLength="50">
                                    <DataBinding ColumnKey="ModelNumber"/>
                                </GridCell>
                                <GridCell Key="ConstYear" Caption="制造年" CellType="NumberEditor" IntegerValue="true" Precision="9" Scale="0">
                                    <DataBinding ColumnKey="ConstYear"/>
                                    <CellFormat HAlign="Right"/>
                                </GridCell>
                                <GridCell Key="ConstMon" Caption="制造月" CellType="NumberEditor" IntegerValue="true" Precision="9" Scale="0">
                                    <DataBinding ColumnKey="ConstMon"/>
                                    <CellFormat HAlign="Right"/>
                                </GridCell>
                                <GridCell Key="OrgCompanyCodeID" Caption="公司代码" CellType="Dict" ItemKey="CompanyCode">
                                    <DataBinding ColumnKey="OrgCompanyCodeID"/>
                                </GridCell>
                                <GridCell Key="AssetCardDocNo" Caption="资产号" CellType="TextEditor" MaxLength="50">
                                    <DataBinding ColumnKey="AssetCardDocNo"/>
                                </GridCell>
                                <GridCell Key="CostCenterID" Caption="成本中心" CellType="Dict" ItemKey="CostCenter">
                                    <DataBinding ColumnKey="CostCenterID"/>
                                </GridCell>
                                <GridCell Key="PlanningPlantID" Caption="计划工厂" CellType="Dict" ItemKey="Plant">
                                    <DataBinding ColumnKey="PlanningPlantID"/>
                                </GridCell>
                                <GridCell Key="PlannerGroupID" Caption="计划员组" CellType="Dict" ItemKey="PM_PlannerGroup">
                                    <DataBinding ColumnKey="PlannerGroupID"/>
                                </GridCell>
                                <GridCell Key="MainWorkCenterID" Caption="主工作中心" CellType="Dict" ItemKey="WorkCenter">
                                    <DataBinding ColumnKey="MainWorkCenterID"/>
                                </GridCell>
                                <GridCell Key="CatalogProfileID" Caption="类别参数文件" CellType="Dict" ItemKey="QM_CatalogProfile">
                                    <DataBinding ColumnKey="CatalogProfileID"/>
                                </GridCell>
                                <GridCell Key="FunctionalLocationSOID" Caption="功能位置" CellType="Dict" ItemKey="PM_FunctionalLocation__Dic" StateMask="Enable|Disable|Discard">
                                    <DataBinding ColumnKey="FunctionalLocationSOID"/>
                                </GridCell>
                                <GridCell Key="SupEquipmentSOID" Caption="高级设备描述" CellType="Dict" ItemKey="PM_Equipment__Dic" StateMask="Enable|Disable|Discard">
                                    <DataBinding ColumnKey="EquipmentSOID"/>
                                </GridCell>
                                <GridCell Key="MaterialID" Caption="物料" CellType="Dict" ItemKey="Material">
                                    <DataBinding ColumnKey="MaterialID"/>
                                </GridCell>
                                <GridCell Key="MaintPlantID" Caption="维护工厂" CellType="Dict" ItemKey="Plant">
                                    <DataBinding ColumnKey="MaintPlantID"/>
                                </GridCell>
                                <GridCell Key="LocationID" Caption="位置" CellType="Dict" ItemKey="Location">
                                    <DataBinding ColumnKey="LocationID"/>
                                </GridCell>
                                <GridCell Key="Room" Caption="房间" CellType="TextEditor" Case="Upper">
                                    <DataBinding ColumnKey="Room"/>
                                </GridCell>
                                <GridCell Key="PlantSectionID" Caption="工厂区域" CellType="Dict" ItemKey="PM_PlantSection">
                                    <DataBinding ColumnKey="PlantSectionID"/>
                                </GridCell>
                                <GridCell Key="WorkCenterID" Caption="工作中心" CellType="Dict" ItemKey="WorkCenter">
                                    <DataBinding ColumnKey="WorkCenterID"/>
                                </GridCell>
                                <GridCell Key="ABCIndicatorID" Caption="ABC标识" CellType="Dict" ItemKey="PM_ABCIndicator">
                                    <DataBinding ColumnKey="ABCIndicatorID"/>
                                    <ItemFilter ItemKey="PM_ABCIndicator">
                                        <Filter Key="Filter" Impl="com.bokesoft.yes.erp.condition.Filter" Type="Custom">
                                            <FilterValue Index="1" ParaValue="' ABCIndicatorType = ' + SqlPara(2)"/>
                                        </Filter>
                                    </ItemFilter>
                                </GridCell>
                                <GridCell Key="Creator" Caption="创建人" CellType="Dict" ItemKey="Operator">
                                    <DataBinding ColumnKey="Creator"/>
                                </GridCell>
                                <GridCell Key="CreateTime" Caption="创建日期" CellType="UTCDatePicker">
                                    <DataBinding ColumnKey="CreateTime"/>
                                </GridCell>
                                <GridCell Key="Modifier" Caption="更改人" CellType="Dict" ItemKey="Operator">
                                    <DataBinding ColumnKey="Modifier"/>
                                </GridCell>
                                <GridCell Key="ModifyTime" Caption="更改时间" CellType="UTCDatePicker">
                                    <DataBinding ColumnKey="ModifyTime"/>
                                </GridCell>
                                <GridCell Key="EquipmentCategoryID" Caption="设备种类" CellType="Dict" ItemKey="PM_EquipmentCategory">
                                    <DataBinding ColumnKey="EquipmentCategoryID"/>
                                </GridCell>
                                <GridCell Key="EquipSerialNumberStatus" Caption="设备和序列号状态" CellType="ComboBox" IntegerValue="true" GroupKey="EquipSerialNumberStatus" SourceType="ParaGroup">
                                    <DataBinding ColumnKey="EquipSerialNumberStatus"/>
                                </GridCell>
                                <GridCell Key="SerialNumber" Caption="序列号" CellType="TextEditor" MaxLength="100">
                                    <DataBinding ColumnKey="SerialNumber"/>
                                </GridCell>
                                <GridCell Key="CategoryTypeID" Caption="类别种类" CellType="Dict" ItemKey="MM_CategoryType">
                                    <DataBinding ColumnKey="CategoryTypeID"/>
                                </GridCell>
                                <GridCell Key="SortField" Caption="分类字段" CellType="TextEditor">
                                    <DataBinding ColumnKey="SortField"/>
                                </GridCell>
                                <GridCell Key="WBSElementID" Caption="WBS元素" CellType="Dict" ItemKey="PS_WBSElement">
                                    <DataBinding ColumnKey="WBSElementID"/>
                                </GridCell>
                                <GridCell Key="ClassificationID" Caption="分类" CellType="Dict" AllowMultiSelection="true" ItemKey="Classification">
                                    <DataBinding ColumnKey="ClassificationID"/>
                                </GridCell>
                                <GridCell Key="BussinessAreaID" Caption="业务范围" CellType="Dict" ItemKey="BusinessArea">
                                    <DataBinding ColumnKey="BusinessAreaID"/>
                                </GridCell>
                                <GridCell Key="SOID" Caption="SOID" CellType="NumberEditor" Scale="0" UseGroupingSeparator="false">
                                    <DataBinding ColumnKey="SOID"/>
                                </GridCell>
                                <GridCell Key="TimeSegmentID" Caption="TimeSegmentID" CellType="NumberEditor" Scale="0" UseGroupingSeparator="false">
                                    <DataBinding ColumnKey="TimeSegmentID"/>
