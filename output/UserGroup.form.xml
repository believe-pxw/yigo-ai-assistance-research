<?xml version="1.0" encoding="UTF-8"?>
<Form Key="UserGroup" Caption="显示用户组" FormType="Entity" InitState="Default" Version="6.1" Platform="PC">

    <!-- 数据源 -->
    <DataSource RefObjectKey="UserGroup" />

    <OperationCollection />

    <Body PopWidth="900" PopHeight="650" Resizable="true">
        <Block Key="mainBlock" Caption="主区域">

            <!-- 表头区域：用户组信息 -->
            <FlexFlowLayoutPanel Key="headerPanel" Caption="用户组">
                <TextEditor Key="UserGroupCode" Caption="用户组" PromptText="请输入用户组">
                    <DataBinding TableKey="UserGroup" ColumnKey="UserGroupCode" />
                </TextEditor>
                <Label Key="lblTemplate" Caption="TEMPLATE" />
                <TextEditor Key="UserGroupText" Caption="文本">
                    <DataBinding TableKey="UserGroup" ColumnKey="UserGroupText" />
                </TextEditor>
            </FlexFlowLayoutPanel>

            <!-- 用户分配明细表格 -->
            <Grid Key="gridUserAssignment" Caption="用户分配"
                  SelectionMode="Row" ShowRowHead="true"
                  PageLoadType="UI" PageRowCount="20">

                <GridColumnCollection>
                    <GridColumn Key="colSelect" Caption="" Width="30" />
                    <GridColumn Key="colUserName" Caption="用户名" Width="120" Sortable="true" />
                    <GridColumn Key="colFullName" Caption="全名" Width="200" Sortable="true" />
                    <GridColumn Key="colAssignSource" Caption="分配来源" Width="150" Sortable="true" />
                </GridColumnCollection>

                <GridRowCollection>
                    <GridRow Key="assignRow" TableKey="UserAssignment">
                        <GridCell Key="cellSelect" CellType="CheckBox" IsSelect="true">
                            <DataBinding TableKey="UserAssignment" ColumnKey="Selected" />
                        </GridCell>
                        <GridCell Key="cellUserName" CellType="TextEditor" Enable="false">
                            <DataBinding TableKey="UserAssignment" ColumnKey="UserName" />
                        </GridCell>
                        <GridCell Key="cellFullName" CellType="TextEditor" Enable="false">
                            <DataBinding TableKey="UserAssignment" ColumnKey="FullName" />
                        </GridCell>
                        <GridCell Key="cellAssignSource" CellType="TextEditor" Enable="false">
                            <DataBinding TableKey="UserAssignment" ColumnKey="AssignSource" />
                        </GridCell>
                    </GridRow>
                </GridRowCollection>

            </Grid>

        </Block>
    </Body>

</Form>
